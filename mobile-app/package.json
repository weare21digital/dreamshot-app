{
  "name": "dreamshot",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "prebuild": "expo prebuild && sh scripts/post-prebuild.sh",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}' --ignore-pattern '!src/**'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix --ignore-pattern '!src/**'",
    "type-check": "tsc --noEmit",
    "build:dev": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform all --profile development",
    "build:preview": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform all --profile preview",
    "build:prod": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform all --profile production",
    "build:dev:android": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform android --profile development",
    "build:dev:ios": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform ios --profile development",
    "build:preview:android": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform android --profile preview",
    "build:preview:ios": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform ios --profile preview",
    "build:prod:android": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform android --profile production",
    "build:prod:ios": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "expo": "^54.0.8",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~6.1.5",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "^1.0.10",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "^55.0.4",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-native": "0.81.5",
    "react-native-iap": "^14.7.7",
    "react-native-mmkv": "^4.1.2",
    "react-native-navigation-bar-color": "^2.0.2",
    "react-native-nitro-modules": "^0.33.5",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.2.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "fast-check": "^4.5.3",
    "jest": "~29.7.0",
    "jest-expo": "^54.0.16",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
