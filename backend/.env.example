# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# For PostgreSQL:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mobile_skeleton_db"
# For MySQL:
# DATABASE_URL="mysql://username:password@localhost:3306/database_name"
# For SQLite (development):
# DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=365d

# Email Configuration (using Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# The "from" email address (must be verified in your Resend account, or use onboarding@resend.dev for testing)
EMAIL_FROM=noreply@yourdomain.com
# Set to true to log codes to console instead of sending emails (for local development)
EMAIL_DEV_MODE=false
# Email template branding - customize per app
EMAIL_HEADER_COLOR=#0d6efd
# Optional: URL to your app's logo (hosted image URL, recommended size: 150x50px)
# EMAIL_LOGO_URL=https://yourdomain.com/logo.png

# App Configuration
APP_NAME="Mobile App Skeleton"
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8081

GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# AI / OpenAI (for backend proxy routes, e.g. /api/ai/background/replace)
# You can set directly:
OPENAI_API_KEY=sk_test_your_openai_key_here
# Or inject from your shell when starting backend (recommended):
# OPENAI_API_KEY="$CLAW_OPEN_API_KEY" npm run dev
# OpenAI image model override
OPENAI_IMAGE_MODEL=gpt-image-1

# fal.ai credentials and model overrides
FAL_API_KEY=fal_test_your_fal_key_here
FAL_IMAGE_MODEL=fal-ai/pulid
FAL_VIDEO_MODEL=fal-ai/wan/v2.2-5b/image-to-video

# Image backend rollout controls
# IMAGE_BACKEND: openai | fal | rollout
IMAGE_BACKEND=openai
# Used only when IMAGE_BACKEND=rollout
GPT_IMAGE_PERCENTAGE=100

# Image request protection
IMAGE_RATE_LIMIT_PER_MINUTE=5
IMAGE_RATE_LIMIT_PER_DAY=50
OPENAI_IMAGE_CONCURRENCY_LIMIT=5

# Estimated cost tracking per generated OpenAI image (USD)
OPENAI_IMAGE_COST_USD=0.08
